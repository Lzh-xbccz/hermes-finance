{
  "mcpServers": {
    "hermes_finance": {
      "command": "python3",
      "args": ["/absolute/path/to/hermes-finance/bin/hermes_finance_mcp.py"],
      "cwd": "/absolute/path/to/hermes-finance",
      "env": {
        "PYTHONPATH": "/absolute/path/to/hermes-finance"
      },
      "timeout": 600000,
      "trust": false
    }
  }
}
